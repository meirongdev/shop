# Ignore everything by default
**

# Allow all pom.xml files at any level
!**/pom.xml

# Allow all source directories
!**/src/**

# Allow shared infrastructure and contracts
!shared/shop-common/**
!shared/shop-contracts/**

# Allow the Dockerfile itself
!platform/docker/Dockerfile.module
!platform/docker/Dockerfile.fast
!platform/docker/Dockerfile.seller-portal
!platform/docker/Dockerfile.buyer-app
!platform/docker/nginx-seller.conf
!platform/docker/nginx-buyer.conf

# Ignore build artifacts and IDE folders
**/target/**
**/build/
.git
.idea
.vscode
.gradle
.tilt
node_modules
*.md

# Allow host-built runtime jars for fast local Docker builds
!**/target/
!**/target/*.jar

# Allow KMP WASM build outputs for seller-portal and buyer-app images
!frontend/kmp/seller-app/build/dist/**
!frontend/kmp/buyer-app/build/dist/**
