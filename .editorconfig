root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,mdx}]
indent_size = 2
trim_trailing_whitespace = false

[*.{yml,yaml,json}]
indent_size = 2

[*.{js,jsx,ts,tsx,css,scss,html}]
indent_size = 2

[*.{sh,bash}]
indent_size = 2

[*.{java,kt,kts,properties,xml}]
indent_size = 4

[Makefile]
indent_style = tab
