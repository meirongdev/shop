{
  "name": "shop-e2e-tests",
  "version": "1.0.0",
  "description": "Playwright end-to-end tests for the shop platform (buyer portal + seller app)",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:buyer": "playwright test --project=buyer",
